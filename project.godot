; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Game Aurora — Vertical Slice"
run/main_scene="res://world/main_menu.tscn"
config/features=PackedStringArray("4.6", "Mobile")

[autoload]

